# Copy this file to .env and fill in your values.
# The backend reads these via python-dotenv.

# Comma-separated list of allowed frontend origins (default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Set to "production" or "development"
ENV=development

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codesentinel

# GitHub OAuth application credentials
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# Callback URL registered in your GitHub OAuth App settings
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/callback

# JWT signing secret – use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
